<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Responsible Teachers Program</title>
<style>
:root{
  --ink:#0f172a;
  --muted:#64748b;
  --border:#e2e8f0;
  --soft:#f8fafc;
  --blue:#2563eb;
  --green:#16a34a;
  --amber:#f59e0b;
  --card:#ffffff;
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:Arial,Helvetica,sans-serif;
  background:linear-gradient(135deg,#f8fafc,#eef2ff);
  color:var(--ink);
  line-height:1.55;
}
.container{max-width:1250px;margin:auto;padding:18px}
.hero{
  background:linear-gradient(135deg,#111827,#2563eb);
  color:white;
  border-radius:26px;
  padding:28px;
  margin-bottom:16px;
  box-shadow:0 18px 42px rgba(15,23,42,.2);
}
.hero h1{font-size:32px;margin-bottom:8px}
.hero p{color:#dbeafe;max-width:850px}
.pills{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}
.pill{
  background:rgba(255,255,255,.14);
  border:1px solid rgba(255,255,255,.25);
  padding:7px 12px;
  border-radius:999px;
  font-weight:900;
  font-size:13px;
}
.panel{
  background:white;
  border:1px solid var(--border);
  border-radius:22px;
  padding:16px;
  margin:14px 0;
  box-shadow:0 8px 22px rgba(15,23,42,.07);
}
.controls{
  display:grid;
  grid-template-columns:1fr 1fr 1.3fr auto;
  gap:10px;
  align-items:end;
}
label{display:block;font-size:13px;font-weight:900;color:#334155;margin-bottom:4px}
select,input{
  width:100%;
  min-height:44px;
  border:1px solid var(--border);
  border-radius:14px;
  padding:11px 12px;
  font-size:14px;
  background:white;
}
button{
  border:0;
  border-radius:14px;
  min-height:44px;
  padding:11px 14px;
  background:#111827;
  color:white;
  font-weight:900;
  cursor:pointer;
}
button.secondary{background:#e2e8f0;color:#111827}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:12px}
.stat{
  background:var(--soft);
  border:1px solid var(--border);
  border-radius:16px;
  text-align:center;
  padding:12px;
}
.stat b{display:block;color:var(--blue);font-size:24px}
.stat span{font-size:12px;color:var(--muted);font-weight:800}
.teacher-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.teacher-card{
  background:white;
  border:1px solid var(--border);
  border-radius:20px;
  padding:14px;
  box-shadow:0 6px 18px rgba(15,23,42,.06);
  position:relative;
  overflow:hidden;
}
.teacher-card:before{
  content:"";
  position:absolute;
  left:0;
  top:0;
  width:6px;
  height:100%;
  background:var(--blue);
}
.teacher-name{font-size:17px;font-weight:900;margin-bottom:8px;padding-right:70px}
.count{
  position:absolute;
  right:12px;
  top:12px;
  background:#eff6ff;
  color:#1d4ed8;
  border:1px solid #bfdbfe;
  border-radius:999px;
  padding:4px 9px;
  font-size:12px;
  font-weight:900;
}
.module{
  background:#f8fafc;
  border:1px solid var(--border);
  border-radius:14px;
  padding:10px;
  margin-top:8px;
}
.module h3{font-size:14px;margin-bottom:5px}
.meta{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
  margin-top:8px;
}
.box{
  background:white;
  border:1px solid var(--border);
  border-radius:12px;
  padding:8px;
  font-size:12px;
}
.box strong{display:block;margin-bottom:3px}
.exam{border-left:4px solid var(--amber)}
.review{border-left:4px solid var(--green)}
.note{font-size:12px;color:var(--muted);margin-top:7px}
.table-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:18px}
table{width:100%;border-collapse:collapse;background:white;min-width:950px;font-size:13px}
th,td{border-bottom:1px solid var(--border);padding:10px;text-align:left;vertical-align:top}
th{background:#f1f5f9;font-weight:900;color:#334155}
tr:hover td{background:#f8fafc}
.view-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
.tab{background:#e0e7ff;color:#1e3a8a}
.tab.active{background:#2563eb;color:white}
.empty{
  padding:28px;
  border:1px dashed var(--border);
  background:#f8fafc;
  color:var(--muted);
  border-radius:18px;
  text-align:center;
}
.footer{text-align:center;color:var(--muted);font-size:13px;padding:20px}
@media(max-width:900px){
  .controls,.stats,.teacher-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:650px){
  .container{padding:10px}
  .hero{padding:20px;border-radius:20px}
  .hero h1{font-size:24px}
  .controls,.stats,.teacher-grid,.meta{grid-template-columns:1fr}
  .panel{padding:12px;border-radius:18px}
  .teacher-card{padding:12px;border-radius:18px}
}
@media print{
  body{background:white}
  .hero,.controls,.view-tabs,.footer,button{display:none!important}
  .panel,.teacher-card,.module{box-shadow:none;border:1px solid #000}
  .teacher-grid{grid-template-columns:1fr}
  th,td{border:1px solid #000}
}
</style>
</head>
<body>
<div class="container">

<section class="hero">
  <h1>Responsible Teachers Program</h1>
  <p>Interactive program for module-responsible teachers. It shows each teacher’s modules, level, replacement exam time, exam room, paper consultation time, and consultation room.</p>
  <div class="pills">
    <span class="pill">Replacement exam room: 210</span>
    <span class="pill">Paper consultation after each exam</span>
    <span class="pill">Filter by teacher, level, or day</span>
  </div>
</section>

<section class="panel">
  <div class="controls">
    <div>
      <label>Teacher</label>
      <select id="teacherFilter">
        <option value="all">All teachers</option>
      </select>
    </div>
    <div>
      <label>Level</label>
      <select id="levelFilter">
        <option value="all">All levels</option>
        <option value="L2">Second Year Licence</option>
        <option value="L3">Third Year Licence</option>
        <option value="M1_IE">Master 1 Industrial Electrotechnics</option>
        <option value="M1_EM">Master 1 Electrical Machines</option>
        <option value="M1_EN">Master 1 Electrical Networks</option>
      </select>
    </div>
    <div>
      <label>Search module</label>
      <input id="searchBox" placeholder="Example: Sampled, Electric, Control">
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button onclick="resetFilters()">Reset</button>
      <button class="secondary" onclick="window.print()">Print</button>
    </div>
  </div>

  <div class="stats">
    <div class="stat"><b id="visibleCount">0</b><span>visible modules</span></div>
    <div class="stat"><b id="teacherCount">0</b><span>teachers shown</span></div>
    <div class="stat"><b>210</b><span>exam room</span></div>
    <div class="stat"><b id="todayCount">0</b><span>today-filtered rows</span></div>
  </div>
</section>

<section class="panel">
  <div class="view-tabs">
    <button id="teacherTab" class="tab active" onclick="setView('teachers')">Teacher cards</button>
    <button id="tableTab" class="tab" onclick="setView('table')">Table</button>
  </div>

  <div id="teacherView" class="teacher-grid"></div>

  <div id="tableView" class="table-wrap" style="display:none">
    <table>
      <thead>
        <tr>
          <th>Teacher</th>
          <th>Module</th>
          <th>Level</th>
          <th>Day</th>
          <th>Replacement exam</th>
          <th>Exam room</th>
          <th>Paper consultation</th>
          <th>Review room</th>
          <th>Note</th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
</section>

<div class="footer">Department of Electrical Engineering — Faculty of Applied Sciences</div>
</div>

