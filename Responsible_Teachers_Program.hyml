art": "13:00", "examEnd": "15:00", "examTime": "13:00 – 15:00", "examRoom": "210", "reviewDate": "2026-05-19", "reviewDay": "Tuesday", "reviewStart": "15:00", "reviewEnd": "17:00", "reviewTime": "15:00 – 17:00", "reviewRoom": "114", "note": "Paper consultation immediately after the replacement exam."}, {"order": 5, "subject": "Entrepreneurship and Business Management", "teacher": "Temejghdeen.F", "levelId": "L3", "levelName": "Third Year Licence — Electrical Engineering", "dayId": "monday", "dayName": "Monday", "examDate": "2026-05-18", "examStart": "08:00", "examEnd": "10:00", "examTime": "08:00 – 10:00", "examRoom": "210", "reviewDate": "2026-05-18", "reviewDay": "Monday", "reviewStart": "10:00", "reviewEnd": "12:00", "reviewTime": "10:00 – 12:00", "reviewRoom": "111", "note": "Paper consultation immediately after the replacement exam."}];

const teacherFilter = document.getElementById("teacherFilter");
const levelFilter = document.getElementById("levelFilter");
const searchBox = document.getElementById("searchBox");
const teacherView = document.getElementById("teacherView");
const tableView = document.getElementById("tableView");
const tableBody = document.getElementById("tableBody");
const visibleCount = document.getElementById("visibleCount");
const teacherCount = document.getElementById("teacherCount");
const todayCount = document.getElementById("todayCount");

function normalize(s){
  return String(s || "").toLowerCase().trim();
}

function initTeachers(){
  const teachers = [...new Set(teacherData.map(x => x.teacher))].sort();
  teacherFilter.innerHTML += teachers.map(t => `<option value="${t}">${t}</option>`).join("");
}

function filtered(){
  const teacher = teacherFilter.value;
  const level = levelFilter.value;
  const q = normalize(searchBox.value);

  return teacherData.filter(x => {
    const okTeacher = teacher === "all" || x.teacher === teacher;
    const okLevel = level === "all" || x.levelId === level;
    const okSearch = !q || normalize(x.subject + " " + x.levelName + " " + x.teacher).includes(q);
    return okTeacher && okLevel && okSearch;
  });
}

function groupByTeacher(rows){
  const groups = {};
  rows.forEach(x => {
    if(!groups[x.teacher]) groups[x.teacher] = [];
    groups[x.teacher].push(x);
  });
  return groups;
}

function renderTeachers(rows){
  const groups = groupByTeacher(rows);
  const names = Object.keys(groups).sort();

  teacherView.innerHTML = names.length ? names.map(name => `
    <article class="teacher-card">
      <div class="count">${groups[name].length} module(s)</div>
      <div class="teacher-name">${name}</div>
      ${groups[name].map(x => `
        <div class="module">
          <h3>${x.subject}</h3>
          <div class="note">${x.levelName}</div>
          <div class="meta">
            <div class="box exam">
              <strong>Replacement exam</strong>
              Day: ${x.dayName}<br>
              Time: ${x.examTime}<br>
              Room: ${x.examRoom}
            </div>
            <div class="box review">
              <strong>Paper consultation</strong>
              Day: ${x.reviewDay}<br>
              Time: ${x.reviewTime}<br>
              Room: ${x.reviewRoom}
            </div>
          </div>
          <div class="note">${x.note}</div>
        </div>
      `).join("")}
    </article>
  `).join("") : `<div class="empty">No teacher program found for the selected filters.</div>`;
}

function renderTable(rows){
  tableBody.innerHTML = rows.map(x => `
    <tr>
      <td><strong>${x.teacher}</strong></td>
      <td>${x.subject}</td>
      <td>${x.levelName}</td>
      <td>${x.dayName}</td>
      <td>${x.examTime}</td>
      <td>${x.examRoom}</td>
      <td>${x.reviewDay}<br>${x.reviewTime}</td>
      <td>${x.reviewRoom}</td>
      <td>${x.note}</td>
    </tr>
  `).join("");
}

function render(){
  const rows = filtered();
  visibleCount.textContent = rows.length;
  teacherCount.textContent = new Set(rows.map(x => x.teacher)).size;
  todayCount.textContent = rows.length;
  renderTeachers(rows);
  renderTable(rows);
}

function setView(view){
  teacherView.style.display = view === "teachers" ? "" : "none";
  tableView.style.display = view === "table" ? "" : "none";
  document.getElementById("teacherTab").classList.toggle("active", view === "teachers");
  document.getElementById("tableTab").classList.toggle("active", view === "table");
}

function resetFilters(){
  teacherFilter.value = "all";
  levelFilter.value = "all";
  searchBox.value = "";
  render();
}

[teacherFilter, levelFilter, searchBox].forEach(el => el.addEventListener("input", render));

initTeachers();
render();
</script>
</body>
</html>
